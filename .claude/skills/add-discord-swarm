### Step 2: Add Webhook Pool to `src/channels/discord.ts`

Read `src/channels/discord.ts` and make these changes:

**1. Add `WebhookClient` to the discord.js import:**

```typescript
import {
  Client,
  Events,
  GatewayIntentBits,
  Message,
  TextChannel,
  WebhookClient,
} from 'discord.js';
```

**2. Add module-level pool state** after the existing imports, before the `DiscordChannelOpts` interface:

```typescript
// Webhook pool for agent swarm: one WebhookClient per slot
const webhookClients: WebhookClient[] = [];
// Maps "{groupFolder}:{senderName}" → webhook index for stable assignment
const senderWebhookMap = new Map<string, number>();
let nextWebhookIndex = 0;
```

**3. Add pool functions** after the module-level state declarations:

```typescript
/**
 * Initialize WebhookClient instances for the webhook pool.
 */
export function initWebhookPool(urls: string[]): void {
  for (const url of urls) {
    try {
      webhookClients.push(new WebhookClient({ url }));
    } catch (err) {
      logger.error({ err }, 'Failed to initialize Discord webhook');
    }
  }
  if (webhookClients.length > 0) {
    logger.info({ count: webhookClients.length }, 'Discord webhook pool ready');
  }
}

/**
 * Send a message via a webhook assigned to the given sender name.
 * Assigns webhooks round-robin on first use; subsequent messages from the
 * same sender in the same group always use the same webhook.
 * The webhook posts with username set to the sender name — no rename delay needed.
 */
export async function sendWebhookMessage(
  jid: string,
  text: string,
  sender: string,
  groupFolder: string,
): Promise<void> {
  if (webhookClients.length === 0) {
    logger.warn('Discord webhook pool empty — falling back to bot sendMessage');
    return;
  }

  const key = `${groupFolder}:${sender}`;
  let idx = senderWebhookMap.get(key);
  if (idx === undefined) {
    idx = nextWebhookIndex % webhookClients.length;
    nextWebhookIndex++;
    senderWebhookMap.set(key, idx);
    logger.info({ sender, groupFolder, webhookIndex: idx }, 'Assigned webhook to sender');
  }

  const webhook = webhookClients[idx];
  const MAX_LENGTH = 2000;
  try {
    if (text.length <= MAX_LENGTH) {
      await webhook.send({ content: text, username: sender });
    } else {
      for (let i = 0; i < text.length; i += MAX_LENGTH) {
        await webhook.send({ content: text.slice(i, i + MAX_LENGTH), username: sender });
      }
    }
    logger.info({ jid, sender, webhookIndex: idx, length: text.length }, 'Discord webhook message sent');
  } catch (err) {
    logger.error({ jid, sender, err }, 'Failed to send Discord webhook message');
  }
}
```

